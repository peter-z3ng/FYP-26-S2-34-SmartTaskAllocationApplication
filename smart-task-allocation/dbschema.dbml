Table user_account {
    user_id uuid [pk]
    role_id int [ref: > role.role_id]
    username varchar unique
    email varchar unique
    created_at timestamptz
    updated_at timestamptz
}

Table role {
    role_id int [pk]
    role_name varchar unique
    description text
    created_at timestamptz
    updated_at timestamptz
}

Table profile {
    profile_id uuid [pk]
    user_id uuid [ref: > user_account.user_id]
    full_name varchar
    bio text
    phone_number varchar
    address text
    created_at timestamptz
    updated_at timestamptz
}